        "telegramApi": {
          "id": "REPLACE_TELEGRAM_CREDENTIAL_ID",
          "name": "Telegram Bot (Insta_Ali_Translate)"
        }
      }
    },
    {
      "parameters": {
        "chatId": "REPLACE_WITH_TELEGRAM_CHAT_ID",
        "text": "={{ `[Insta_Ali_Translate] 작업 타임아웃 ⏱️\\nJob: ${$('Set Job ID').item.json.job_id}\\nURL: ${$('Set Job ID').item.json.product_url}\\n60회 폴링(약 30분) 후에도 완료되지 않았습니다.` }}",
        "additionalFields": {}
      },
      "id": "a3b4c5d6-e7f8-9012-6789-123456789012",
